{
  "info": {
    "name": "Nibras - P0 Tests (Ilham)",
    "description": "Tests automatisés pour Projects API et Teams & Members API.\n\nAvant de lancer :\n1. Lance le serveur : bun run index.ts\n2. Dans Postman, crée un Environment avec les variables : baseUrl = http://localhost:3000\n3. Lance les requêtes dans l'ordre (1 → 2 → ... → 26) car chaque test dépend du précédent.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "0. SETUP — Login + Assign Roles",
      "item": [
        {
          "name": "01. Register managerA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/register",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"managerA\",\n  \"email\": \"managera@test.com\",\n  \"password\": \"test123\",\n  \"confirmPassword\": \"test123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (pm.response.code === 200 && json.accessToken) {",
            "  pm.collectionVariables.set('tokenA_temp', json.accessToken);",
            "  console.log('managerA registered');",
            "} else if (pm.response.code === 409) {",
            "  console.log('managerA already exists, will login');",
            "}"
          ]}}]
        },
        {
          "name": "02. Login managerA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"managera@test.com\",\n  \"password\": \"test123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Login managerA - 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.collectionVariables.set('tokenA_temp', json.accessToken);",
            "console.log('managerA token (temp):', json.accessToken.substring(0, 30) + '...');"
          ]}}]
        },
        {
          "name": "03. Assign role manager to managerA",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA_temp}}" }
            ],
            "url": "{{baseUrl}}/user/role",
            "body": { "mode": "raw", "raw": "{ \"role\": \"manager\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('tokenA', json.accessToken);",
            "  console.log('managerA role assigned');",
            "} else if (pm.response.code === 409) {",
            "  pm.collectionVariables.set('tokenA', pm.collectionVariables.get('tokenA_temp'));",
            "  console.log('Role already assigned, using temp token');",
            "}"
          ]}}]
        },
