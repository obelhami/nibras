{
  "info": {
    "name": "Nibras - P0 Tests (Ilham)",
    "description": "Tests automatisés Projects API + Teams API. Environment requis : baseUrl = http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "tokenA", "value": "" },
    { "key": "tokenA_temp", "value": "" },
    { "key": "tokenB", "value": "" },
    { "key": "tokenB_temp", "value": "" },
    { "key": "tokenAdmin", "value": "" },
    { "key": "tokenAdmin_temp", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "projectIdFilter", "value": "" },
    { "key": "projectIdScope", "value": "" },
    { "key": "teamId", "value": "" },
    { "key": "memberBId", "value": "" }
  ],
  "item": [
    {
      "name": "0. SETUP",
      "item": [
        {
          "name": "01. Register managerA",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/register", "body": { "mode": "raw", "raw": "{\"username\":\"managerA\",\"email\":\"managera@test.com\",\"password\":\"test123\",\"confirmPassword\":\"test123\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json();", "if (pm.response.code === 200 && json.accessToken) { pm.collectionVariables.set('tokenA_temp', json.accessToken); }"] } }]
        },
        {
          "name": "02. Login managerA",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/login", "body": { "mode": "raw", "raw": "{\"email\":\"managera@test.com\",\"password\":\"test123\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Login managerA - 200 OK', () => pm.response.to.have.status(200));", "pm.collectionVariables.set('tokenA_temp', pm.response.json().accessToken);"] } }]
        },
        {
          "name": "03. Assign role manager to managerA",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA_temp}}" }], "url": "{{baseUrl}}/user/role", "body": { "mode": "raw", "raw": "{\"role\":\"manager\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json();", "if (pm.response.code === 200) { pm.collectionVariables.set('tokenA', json.accessToken); } else { pm.collectionVariables.set('tokenA', pm.collectionVariables.get('tokenA_temp')); }"] } }]
        },
        {
          "name": "04. Login managerB",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/login", "body": { "mode": "raw", "raw": "{\"email\":\"managerb@test.com\",\"password\":\"test123\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Login managerB - 200 OK', () => pm.response.to.have.status(200));", "pm.collectionVariables.set('tokenB_temp', pm.response.json().accessToken);"] } }]
        },
        {
          "name": "05. Assign role manager to managerB",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenB_temp}}" }], "url": "{{baseUrl}}/user/role", "body": { "mode": "raw", "raw": "{\"role\":\"manager\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json();", "if (pm.response.code === 200) { pm.collectionVariables.set('tokenB', json.accessToken); } else { pm.collectionVariables.set('tokenB', pm.collectionVariables.get('tokenB_temp')); }"] } }]
        },
        {
          "name": "06. Login admin1",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{baseUrl}}/login", "body": { "mode": "raw", "raw": "{\"email\":\"admin1@test.com\",\"password\":\"test123\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Login admin1 - 200 OK', () => pm.response.to.have.status(200));", "pm.collectionVariables.set('tokenAdmin_temp', pm.response.json().accessToken);"] } }]
        },
        {
          "name": "07. Assign role admin to admin1",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenAdmin_temp}}" }], "url": "{{baseUrl}}/user/role", "body": { "mode": "raw", "raw": "{\"role\":\"admin\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json();", "if (pm.response.code === 200) { pm.collectionVariables.set('tokenAdmin', json.accessToken); } else { pm.collectionVariables.set('tokenAdmin', pm.collectionVariables.get('tokenAdmin_temp')); }"] } }]
        }
      ]
    },
    {
      "name": "1. PROJECTS API - CRUD",
      "item": [
        {
          "name": "08. [CRUD-Create] POST /projects",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\"name\":\"Projet Test Postman\",\"status\":\"active\",\"startDate\":\"2026-07-01\",\"endDate\":\"2026-09-30\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Create] 200 OK', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('message = Project created successfully', () => pm.expect(json.message).to.eql('Project created successfully'));", "pm.test('project.id existe', () => pm.expect(json.project.id).to.be.a('string'));", "pm.collectionVariables.set('projectId', json.project.id);"] } }]
        },
        {
          "name": "09. [CRUD-Read] GET /projects/:id",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects/{{projectId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Read] 200 OK', () => pm.response.to.have.status(200));", "pm.test('project.id correspond', () => pm.expect(pm.response.json().project.id).to.eql(pm.collectionVariables.get('projectId')));"] } }]
        },
        {
          "name": "10. [CRUD-Update] PATCH /projects/:id",
          "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects/{{projectId}}", "body": { "mode": "raw", "raw": "{\"status\":\"on_hold\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Update] 200 OK', () => pm.response.to.have.status(200));", "pm.test('status = on_hold', () => pm.expect(pm.response.json().project.status).to.eql('on_hold'));"] } }]
        },
        {
          "name": "11. [CRUD-Delete] DELETE par manager - 403",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects/{{projectId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Delete manager] 403', () => pm.response.to.have.status(403));", "pm.test('code = FORBIDDEN', () => pm.expect(pm.response.json().code).to.eql('FORBIDDEN'));"] } }]
        },
        {
          "name": "12. [CRUD-Delete] DELETE par admin - 200",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }], "url": "{{baseUrl}}/projects/{{projectId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Delete admin] 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "13. [CRUD-Delete] GET après suppression - 404",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }], "url": "{{baseUrl}}/projects/{{projectId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Delete] 404 après suppression', () => pm.response.to.have.status(404));", "pm.test('code = NOT_FOUND', () => pm.expect(pm.response.json().code).to.eql('NOT_FOUND'));"] } }]
        }
      ]
    },
    {
      "name": "2. PROJECTS API - Validate name/status/dates",
      "item": [
        {
          "name": "14. [Validate-name] nom vide - 400",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\"name\":\"\",\"status\":\"active\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Validate-name] 400', () => pm.response.to.have.status(400));", "pm.test('code = VALIDATION_ERROR', () => pm.expect(pm.response.json().code).to.eql('VALIDATION_ERROR'));"] } }]
        },
        {
          "name": "15. [Validate-status] statut invalide - 400",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\"name\":\"Test\",\"status\":\"invalid_status\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Validate-status] 400', () => pm.response.to.have.status(400));", "pm.test('code = VALIDATION_ERROR', () => pm.expect(pm.response.json().code).to.eql('VALIDATION_ERROR'));"] } }]
        },
        {
          "name": "16. [Validate-dates] startDate > endDate - 400",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\"name\":\"Test\",\"status\":\"active\",\"startDate\":\"2026-09-30\",\"endDate\":\"2026-06-01\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Validate-dates] 400', () => pm.response.to.have.status(400));", "pm.test('code = VALIDATION_ERROR', () => pm.expect(pm.response.json().code).to.eql('VALIDATION_ERROR'));"] } }]
        }
      ]
    },
    {
      "name": "3. PROJECTS API - Filter + Pagination",
      "item": [
        {
          "name": "17. [Filter] Créer projet pour tests",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\"name\":\"Projet Pagination\",\"status\":\"active\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));", "pm.collectionVariables.set('projectIdFilter', pm.response.json().project.id);"] } }]
        },
        {
          "name": "18. [Filter] GET ?status=active",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": { "raw": "{{baseUrl}}/projects?status=active", "host": ["{{baseUrl}}"], "path": ["projects"], "query": [{ "key": "status", "value": "active" }] } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Filter] 200 OK', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('tous les projets sont active', () => { json.projects.forEach(p => pm.expect(p.status).to.eql('active')); });"] } }]
        },
        {
          "name": "19. [Pagination] GET ?page=1&limit=2",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": { "raw": "{{baseUrl}}/projects?page=1&limit=2", "host": ["{{baseUrl}}"], "path": ["projects"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "2" }] } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Pagination] 200 OK', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('max 2 projets', () => pm.expect(json.projects.length).to.be.at.most(2));", "pm.test('pagination.page = 1', () => pm.expect(json.pagination.page).to.eql(1));", "pm.test('pagination.limit = 2', () => pm.expect(json.pagination.limit).to.eql(2));", "pm.test('totalPages cohérent', () => pm.expect(json.pagination.totalPages).to.eql(Math.ceil(json.pagination.total / 2)));"] } }]
        }
      ]
    },
    {
      "name": "4. PROJECTS API - Manager/admin control",
      "item": [
        {
          "name": "20. [Scope] Créer projet managerA",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/projects", "body": { "mode": "raw", "raw": "{\"name\":\"Projet Scope\",\"status\":\"active\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));", "pm.collectionVariables.set('projectIdScope', pm.response.json().project.id);"] } }]
        },
        {
          "name": "21. [Scope] GET /projects par managerB - projet absent",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }], "url": "{{baseUrl}}/projects" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Scope] 200 OK', () => pm.response.to.have.status(200));", "const found = pm.response.json().projects.find(p => p.id === pm.collectionVariables.get('projectIdScope'));", "pm.test('projet managerA absent pour managerB', () => pm.expect(found).to.be.undefined);"] } }]
        },
        {
          "name": "22. [Scope] GET /projects/:id par managerB - 403",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }], "url": "{{baseUrl}}/projects/{{projectIdScope}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Scope] 403 Forbidden', () => pm.response.to.have.status(403));", "pm.test('code = FORBIDDEN', () => pm.expect(pm.response.json().code).to.eql('FORBIDDEN'));"] } }]
        },
        {
          "name": "23. [Scope] GET /projects par admin - voit tout",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }], "url": "{{baseUrl}}/projects" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Scope] admin 200 OK', () => pm.response.to.have.status(200));", "const found = pm.response.json().projects.find(p => p.id === pm.collectionVariables.get('projectIdScope'));", "pm.test('admin voit le projet de managerA', () => pm.expect(found).to.not.be.undefined);"] } }]
        },
        {
          "name": "24. [Scope] DELETE par admin - 200",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }], "url": "{{baseUrl}}/projects/{{projectIdScope}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Scope] DELETE admin 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
    {
      "name": "5. TEAMS API - CRUD",
      "item": [
        {
          "name": "25. [CRUD-Create] POST /teams",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams", "body": { "mode": "raw", "raw": "{\"name\":\"Team Postman\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Create] 200 OK', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('message = Team created successfully', () => pm.expect(json.message).to.eql('Team created successfully'));", "pm.collectionVariables.set('teamId', json.team.id);"] } }]
        },
        {
          "name": "26. [CRUD-Read] GET /teams/:id",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Read] 200 OK', () => pm.response.to.have.status(200));", "pm.test('members vide', () => pm.expect(pm.response.json().members.length).to.eql(0));"] } }]
        },
        {
          "name": "27. [CRUD-Update] PATCH /teams/:id",
          "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}", "body": { "mode": "raw", "raw": "{\"name\":\"Team Postman Renamed\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Update] 200 OK', () => pm.response.to.have.status(200));", "pm.test('nom mis à jour', () => pm.expect(pm.response.json().team.name).to.eql('Team Postman Renamed'));"] } }]
        },
        {
          "name": "28. [CRUD-Delete] DELETE par non-manager - 403",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }], "url": "{{baseUrl}}/teams/{{teamId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[CRUD-Delete] 403', () => pm.response.to.have.status(403));", "pm.test('code = FORBIDDEN', () => pm.expect(pm.response.json().code).to.eql('FORBIDDEN'));"] } }]
        }
      ]
    },
    {
      "name": "6. TEAMS API - Members",
      "item": [
        {
          "name": "29. [Add-member] POST /teams/:id/members",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}/members", "body": { "mode": "raw", "raw": "{\"email\":\"managerb@test.com\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Add-member] 200 OK', () => pm.response.to.have.status(200));", "pm.test('message = Member added successfully', () => pm.expect(pm.response.json().message).to.eql('Member added successfully'));"] } }]
        },
        {
          "name": "30. [Prevent-duplicates] doublon - 409",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}/members", "body": { "mode": "raw", "raw": "{\"email\":\"managerb@test.com\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Prevent-duplicates] 409', () => pm.response.to.have.status(409));", "pm.test('code = CONFLICT', () => pm.expect(pm.response.json().code).to.eql('CONFLICT'));"] } }]
        },
        {
          "name": "31. [List-members] GET /teams/:id/members",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}/members" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[List-members] 200 OK', () => pm.response.to.have.status(200));", "const memberB = pm.response.json().members.find(m => m.email === 'managerb@test.com');", "pm.test('managerB visible', () => pm.expect(memberB).to.not.be.undefined);", "if (memberB) pm.collectionVariables.set('memberBId', String(memberB.id));"] } }]
        },
        {
          "name": "32. [Remove-member] DELETE /teams/:id/members/:userId",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}/members/{{memberBId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[Remove-member] 200 OK', () => pm.response.to.have.status(200));", "pm.test('message = Member removed successfully', () => pm.expect(pm.response.json().message).to.eql('Member removed successfully'));"] } }]
        }
      ]
    },
    {
      "name": "7. TEAMS API - manager_id control",
      "item": [
        {
          "name": "33. [manager_id] PATCH par non-manager - 403",
          "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenB}}" }], "url": "{{baseUrl}}/teams/{{teamId}}", "body": { "mode": "raw", "raw": "{\"name\":\"Hack\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[manager_id] PATCH 403', () => pm.response.to.have.status(403));", "pm.test('code = FORBIDDEN', () => pm.expect(pm.response.json().code).to.eql('FORBIDDEN'));"] } }]
        },
        {
          "name": "34. [manager_id] Add member par non-manager - 403",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tokenB}}" }], "url": "{{baseUrl}}/teams/{{teamId}}/members", "body": { "mode": "raw", "raw": "{\"email\":\"admin1@test.com\"}" } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[manager_id] Add member 403', () => pm.response.to.have.status(403));", "pm.test('code = FORBIDDEN', () => pm.expect(pm.response.json().code).to.eql('FORBIDDEN'));"] } }]
        },
        {
          "name": "35. [manager_id] GET /teams par managerB - team absente",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }], "url": "{{baseUrl}}/teams" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[manager_id] GET teams 200', () => pm.response.to.have.status(200));", "const found = pm.response.json().teams.find(t => t.id === pm.collectionVariables.get('teamId'));", "pm.test('team absente pour managerB', () => pm.expect(found).to.be.undefined);"] } }]
        },
        {
          "name": "36. [manager_id] DELETE par propriétaire - 200",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }], "url": "{{baseUrl}}/teams/{{teamId}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('[manager_id] DELETE 200', () => pm.response.to.have.status(200));", "pm.test('message = Team deleted successfully', () => pm.expect(pm.response.json().message).to.eql('Team deleted successfully'));"] } }]
        }
      ]
    }
  ]
}
