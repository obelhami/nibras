    {
      "name": "1. PROJECTS API — CRUD",
      "item": [
        {
          "name": "10. [CRUD-Create] POST /projects — succès",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/projects",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Projet Test Postman\",\n  \"status\": \"active\",\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-09-30\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[CRUD-Create] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Project created successfully', () => pm.expect(json.message).to.eql('Project created successfully'));",
            "pm.test('project.id existe', () => pm.expect(json.project.id).to.be.a('string'));",
            "pm.test('project.name correct', () => pm.expect(json.project.name).to.eql('Projet Test Postman'));",
            "pm.test('project.status = active', () => pm.expect(json.project.status).to.eql('active'));",
            "pm.collectionVariables.set('projectId', json.project.id);",
            "console.log('projectId sauvegardé:', json.project.id);"
          ]}}]
        },
        {
          "name": "11. [CRUD-Read] GET /projects/:id — succès",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": "{{baseUrl}}/projects/{{projectId}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[CRUD-Read] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('project.id correspond', () => pm.expect(json.project.id).to.eql(pm.collectionVariables.get('projectId')));",
            "pm.test('project.name correct', () => pm.expect(json.project.name).to.eql('Projet Test Postman'));"
          ]}}]
        },
        {
          "name": "12. [CRUD-Update] PATCH /projects/:id — succès",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "body": { "mode": "raw", "raw": "{ \"status\": \"on_hold\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[CRUD-Update] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('statut mis à jour = on_hold', () => pm.expect(json.project.status).to.eql('on_hold'));"
          ]}}]
        },
        {
          "name": "13. [CRUD-Delete] DELETE /projects/:id par manager — 403",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": "{{baseUrl}}/projects/{{projectId}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[CRUD-Delete manager] 403 Forbidden', () => pm.response.to.have.status(403));",
            "const json = pm.response.json();",
            "pm.test('code = FORBIDDEN', () => pm.expect(json.code).to.eql('FORBIDDEN'));"
          ]}}]
        },
        {
          "name": "14. [CRUD-Delete] DELETE /projects/:id par admin — 200",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/projects/{{projectId}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[CRUD-Delete admin] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Project deleted successfully', () => pm.expect(json.message).to.eql('Project deleted successfully'));"
          ]}}]
        },
        {
          "name": "15. [CRUD-Delete] GET /projects/:id après suppression — 404",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/projects/{{projectId}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[CRUD-Delete] 404 après suppression', () => pm.response.to.have.status(404));",
            "const json = pm.response.json();",
            "pm.test('code = NOT_FOUND', () => pm.expect(json.code).to.eql('NOT_FOUND'));"
          ]}}]
        }
      ]
    },
