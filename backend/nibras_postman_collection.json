          ]}}]
        },
        {
          "name": "23. [Pagination] GET /projects?page=1&limit=2",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/projects?page=1&limit=2",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "2" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Pagination] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('max 2 projets retournés', () => pm.expect(json.projects.length).to.be.at.most(2));",
            "pm.test('pagination.page = 1', () => pm.expect(json.pagination.page).to.eql(1));",
            "pm.test('pagination.limit = 2', () => pm.expect(json.pagination.limit).to.eql(2));",
