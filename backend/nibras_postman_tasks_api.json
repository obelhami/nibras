{
  "info": {
    "name": "Nibras - P0 Tasks API Polish (Ilham)",
    "description": "Tests automatisés pour Tasks API Polish.\n\nPré-requis :\n1. Serveur lancé : bun run index.ts\n2. Environment Postman avec baseUrl = http://localhost:3000\n3. Lancer d'abord la collection Projects+Teams pour avoir managerA avec rôle manager en base",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "tokenA", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "commentId", "value": "" }
  ],
  "item": [
    {
      "name": "0. SETUP",
      "item": [
        {
          "name": "01. Login managerA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"managera@test.com\",\n  \"password\": \"test123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Login managerA - 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.collectionVariables.set('tokenA', json.accessToken);",
            "console.log('Token managerA sauvegardé');"
          ]}}]
        },
        {
          "name": "02. Créer un board de test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Board Test Tasks API\",\n  \"visibility\": \"public\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Création board - 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.collectionVariables.set('boardId', json.board.id);",
            "console.log('boardId sauvegardé:', json.board.id);"
          ]}}]
        }
      ]
    },
    {
      "name": "1. CRUD + Priority/Deadline/Complexity",
      "item": [
        {
          "name": "03. [Create] POST /boards/:boardId/tasks — priority/complexity/dueDate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Tâche Test Tasks API\",\n  \"description\": \"Test complet Tasks API polish\",\n  \"priority\": \"high\",\n  \"complexity\": 3,\n  \"dueDate\": \"2026-07-30\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Create] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Task created successfully', () => pm.expect(json.message).to.eql('Task created successfully'));",
            "pm.test('task.priority = high', () => pm.expect(json.task.priority).to.eql('high'));",
            "pm.test('task.complexity = 3', () => pm.expect(json.task.complexity).to.eql(3));",
            "pm.test('task.dueDate = 2026-07-30', () => pm.expect(json.task.dueDate).to.eql('2026-07-30'));",
            "pm.collectionVariables.set('taskId', json.task.id);",
            "console.log('taskId sauvegardé:', json.task.id);"
          ]}}]
        },
        {
          "name": "04. [Validate-priority] priority invalide — 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test\",\n  \"priority\": \"ultra_high\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Validate-priority] 400 priority invalide', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('message mentionne priority', () => pm.expect(json.message.toLowerCase()).to.include('priority'));"
          ]}}]
        },
        {
          "name": "05. [Validate-complexity] complexity hors range — 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test\",\n  \"complexity\": 10\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Validate-complexity] 400 complexity hors range', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('message mentionne complexity', () => pm.expect(json.message.toLowerCase()).to.include('complexity'));"
          ]}}]
        }
      ]
    },
    {
      "name": "2. Pagination and filters",
      "item": [
        {
          "name": "06. [Pagination] GET /boards/:boardId/tasks?page=1&limit=10&priority=high",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/tasks?page=1&limit=10&priority=high",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "priority", "value": "high" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Pagination] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('tasks est un tableau', () => pm.expect(json.tasks).to.be.an('array'));",
            "pm.test('pagination présente', () => pm.expect(json.pagination).to.exist);",
            "pm.test('pagination.page = 1', () => pm.expect(json.pagination.page).to.eql(1));",
            "pm.test('pagination.limit = 10', () => pm.expect(json.pagination.limit).to.eql(10));",
            "pm.test('toutes les tâches sont priority high', () => {",
            "  json.tasks.forEach(t => pm.expect(t.priority).to.eql('high'));",
            "});",
            "pm.test('riskScore présent dans la réponse', () => {",
            "  json.tasks.forEach(t => pm.expect(t).to.have.property('riskScore'));",
            "});",
            "pm.test('assignees présent dans la réponse', () => {",
            "  json.tasks.forEach(t => pm.expect(t.assignees).to.be.an('array'));",
            "});"
          ]}}]
        },
        {
          "name": "07. [Filter] GET tasks?priority=invalide — 400",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/tasks?priority=invalide",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "tasks"],
              "query": [{ "key": "priority", "value": "invalide" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Filter] priority invalide - 400', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('code = VALIDATION_ERROR', () => pm.expect(json.code).to.eql('VALIDATION_ERROR'));"
          ]}}]
        },
        {
          "name": "08. [Filter] GET tasks?status=todo — filtre par statut",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/tasks?status=todo",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "tasks"],
              "query": [{ "key": "status", "value": "todo" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Filter] GET tasks par status=todo - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('toutes les tâches sont status_slug todo', () => {",
            "  json.tasks.forEach(t => pm.expect(t.status_slug).to.eql('todo'));",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "3. riskScore",
      "item": [
        {
          "name": "09. [riskScore] PATCH riskScore = 75 — succès",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/riskScore",
            "body": { "mode": "raw", "raw": "{ \"riskScore\": 75 }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[riskScore] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('riskScore = 75', () => pm.expect(json.riskScore).to.eql(75));"
          ]}}]
        },
        {
          "name": "10. [riskScore] riskScore > 100 — 400",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/riskScore",
            "body": { "mode": "raw", "raw": "{ \"riskScore\": 150 }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[riskScore] 400 valeur invalide', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('code = VALIDATION_ERROR', () => pm.expect(json.code).to.eql('VALIDATION_ERROR'));"
          ]}}]
        },
        {
          "name": "11. [riskScore] riskScore = null — reset",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/riskScore",
            "body": { "mode": "raw", "raw": "{ \"riskScore\": null }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[riskScore] reset null - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('riskScore = null', () => pm.expect(json.riskScore).to.be.null);"
          ]}}]
        }
      ]
    },
    {
      "name": "4. Backend comments",
      "item": [
        {
          "name": "12. [Comment] POST comment — succès",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/comments",
            "body": { "mode": "raw", "raw": "{ \"content\": \"Premier commentaire de test\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Comment] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Comment added successfully', () => pm.expect(json.message).to.eql('Comment added successfully'));",
            "pm.test('comment.id existe', () => pm.expect(json.comment.id).to.be.a('string'));",
            "pm.test('comment.content correct', () => pm.expect(json.comment.content).to.eql('Premier commentaire de test'));",
            "pm.collectionVariables.set('commentId', json.comment.id);"
          ]}}]
        },
        {
          "name": "13. [Comment] POST comment vide — 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/comments",
            "body": { "mode": "raw", "raw": "{ \"content\": \"\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Comment] contenu vide - 400', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('code = VALIDATION_ERROR', () => pm.expect(json.code).to.eql('VALIDATION_ERROR'));"
          ]}}]
        },
        {
          "name": "14. [Comment] GET comments — liste paginée",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/comments?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "tasks", "{{taskId}}", "comments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Comment] GET comments - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('comments est un tableau', () => pm.expect(json.comments).to.be.an('array'));",
            "pm.test('pagination présente', () => pm.expect(json.pagination).to.exist);",
            "pm.test('au moins 1 commentaire', () => pm.expect(json.comments.length).to.be.above(0));"
          ]}}]
        }
      ]
    },
    {
      "name": "5. Assignment (multiple users)",
      "item": [
        {
          "name": "15. [Assign] POST assignees — succès",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/assignees",
            "body": { "mode": "raw", "raw": "{ \"email\": \"managera@test.com\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Assign] 200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Assignee added successfully', () => pm.expect(json.message).to.eql('Assignee added successfully'));",
            "pm.test('assignees contient managera', () => pm.expect(json.assignees).to.include('managera@test.com'));"
          ]}}]
        },
        {
          "name": "16. [Assign] POST 2ème assigné — multi-assignees",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/assignees",
            "body": { "mode": "raw", "raw": "{ \"email\": \"managerb@test.com\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Assign] 200 OK 2ème assigné', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('assignees contient 2 utilisateurs', () => pm.expect(json.assignees.length).to.eql(2));",
            "pm.test('assignees contient managerb', () => pm.expect(json.assignees).to.include('managerb@test.com'));"
          ]}}]
        },
        {
          "name": "17. [Assign] DELETE assigné — remove",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskId}}/assignees/managerb@test.com"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Assign] DELETE assigné - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Assignee removed successfully', () => pm.expect(json.message).to.eql('Assignee removed successfully'));",
            "pm.test('managerb retiré', () => pm.expect(json.assignees).to.not.include('managerb@test.com'));"
          ]}}]
        }
      ]
    },
    {
      "name": "6. Close with business validation",
      "item": [
        {
          "name": "18. [Close] Créer une tâche sans assigné pour tester le refus",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Tâche sans assigné\",\n  \"priority\": \"medium\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Création tâche sans assigné - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.collectionVariables.set('taskIdUnassigned', json.task.id);"
          ]}}]
        },
        {
          "name": "19. [Close] Close sans assigné — 400 VALIDATION_ERROR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskIdUnassigned}}/close",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Close] sans assigné - 400', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('code = VALIDATION_ERROR', () => pm.expect(json.code).to.eql('VALIDATION_ERROR'));",
            "pm.test('message mentionne assigned', () => pm.expect(json.message.toLowerCase()).to.include('assign'));"
          ]}}]
        },
        {
          "name": "20. [Close] Assigner la tâche",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskIdUnassigned}}/assignees",
            "body": { "mode": "raw", "raw": "{ \"email\": \"managera@test.com\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Assignation - 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "21. [Close] Close avec assigné — 200 status done",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskIdUnassigned}}/close",
            "body": { "mode": "raw", "raw": "{ \"note\": \"Fermé via test Postman\" }" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Close] avec assigné - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('message = Task closed successfully', () => pm.expect(json.message).to.eql('Task closed successfully'));",
            "pm.test('task.status = done', () => pm.expect(json.task.status).to.eql('done'));"
          ]}}]
        },
        {
          "name": "22. [Close] Close une tâche déjà fermée — 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskIdUnassigned}}/close",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Close] déjà fermée - 400', () => pm.response.to.have.status(400));",
            "const json = pm.response.json();",
            "pm.test('code = VALIDATION_ERROR', () => pm.expect(json.code).to.eql('VALIDATION_ERROR'));",
            "pm.test('message mentionne already', () => pm.expect(json.message.toLowerCase()).to.include('already'));"
          ]}}]
        },
        {
          "name": "23. [History] Vérifier que le close a généré un historique",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks/{{taskIdUnassigned}}/history"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[History] GET history - 200', () => pm.response.to.have.status(200));",
