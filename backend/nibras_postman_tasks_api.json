          ]}}]
        },
        {
          "name": "25. [Delete] GET tasks après suppression — tâche absente",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}/tasks"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('[Delete] GET tasks après suppression - 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "const taskId = pm.collectionVariables.get('taskId');",
            "const found = json.tasks.find(t => t.id === taskId);",
            "pm.test('tâche supprimée absente de la liste', () => pm.expect(found).to.be.undefined);"
          ]}}]
        }
      ]
    }
  ],
  "variable": [
    { "key": "tokenA", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "taskIdUnassigned", "value": "" },
    { "key": "commentId", "value": "" }
  ]
}
